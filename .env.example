# PEG Stock Valuation Microservice Configuration

# Server port
PORT=3000

# Finnhub API Key (REQUIRED - either here or in request body)
# Get one at: https://finnhub.io
# If set here, you don't need to provide it in each API request
FINNHUB_API_KEY=d6atr2hr01qnr27isklgd6atr2hr01qnr27iskm0

# Alpha Vantage API Key (OPTIONAL - either here or in request body)
# Get one at: https://www.alphavantage.co
# If set here, you don't need to provide it in each API request
ALPHA_VANTAGE_API_KEY=1DIG8Y0JOY7LQTOY

# ============================================================
# USAGE NOTES:
# ============================================================
# 1. If FINNHUB_API_KEY is set in this file, users can call:
#    POST /api/valuation with just {"symbol": "AAPL"}
#
# 2. If FINNHUB_API_KEY is NOT set, users must provide it in request:
#    POST /api/valuation with {"symbol": "AAPL", "finnhubApiKey": "..."}
#
# 3. API keys in request body override environment variables
#
# 4. For n8n integration or automated systems, set keys here
#    For public APIs, require keys in request body
# ============================================================
